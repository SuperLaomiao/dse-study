generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FamilyRole {
  mom_admin
  learner
}

enum MembershipStatus {
  invited
  active
  inactive
}

enum LearnerTrack {
  dse
  foundation_to_dse
  companion
}

enum SchoolStage {
  p5
  f3
  adult
  other
}

model User {
  id                  String                  @id @default(uuid())
  email               String                  @unique
  displayName         String
  passwordHash        String?
  preferredUiLanguage String                  @default("en")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  memberships         FamilyMembership[]
  createdFamilies     Family[]                @relation("FamilyCreator")
  learnerProfile      LearnerProfile?
  assessments         AssessmentResult[]
  vocabularyProgress  UserVocabulary[]
  speakingProgress    UserSpeakingPractice[]
  speakingRecordings  SpeakingRecording[]
  readingPractices    UserReadingPractice[]
  listeningPractices  UserListeningPractice[]
  writingPractices    UserWritingPractice[]
  biweeklyReviews     BiWeeklyReview[]
  UserGrammarPractice UserGrammarPractice[]
}

model Family {
  id              String             @id @default(uuid())
  name            String
  createdByUserId String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdByUser   User               @relation("FamilyCreator", fields: [createdByUserId], references: [id])
  memberships     FamilyMembership[]
  invites         FamilyInvite[]
  learnerProfiles LearnerProfile[]
}

model FamilyMembership {
  id       String           @id @default(uuid())
  familyId String
  userId   String
  role     FamilyRole
  status   MembershipStatus @default(active)
  joinedAt DateTime         @default(now())
  family   Family           @relation(fields: [familyId], references: [id])
  user     User             @relation(fields: [userId], references: [id])

  @@unique([familyId, userId])
}

model FamilyInvite {
  id          String    @id @default(uuid())
  familyId    String
  email       String
  role        FamilyRole @default(learner)
  inviteToken String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  family      Family   @relation(fields: [familyId], references: [id])

  @@unique([familyId, email])
}

model LearnerProfile {
  id                   String             @id @default(uuid())
  userId               String             @unique
  familyId             String
  profileName          String
  track                LearnerTrack
  schoolStage          SchoolStage
  studyMinutesPerDay   Int                @default(45)
  studyDaysPerWeek     Int                @default(6)
  targetReferenceLevel String
  targetInternalBand   String
  isAdminViewOnly      Boolean            @default(false)
  lastBiWeeklyReview   DateTime?
  nextBiWeeklyReview   DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id])
  family               Family             @relation(fields: [familyId], references: [id])
  assessments          AssessmentResult[]
  biweeklyReviews      BiWeeklyReview[]
}

model AssessmentResult {
  id               String         @id @default(uuid())
  userId           String
  learnerProfileId String
  correctAnswers   Int
  totalQuestions   Int
  calculatedLevel  Int
  calculatedBand   String
  createdAt        DateTime       @default(now())
  learnerProfile   LearnerProfile @relation(fields: [learnerProfileId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
}

model Vocabulary {
  id              String           @id @default(uuid())
  word            String           @unique
  definition      String
  difficultyLevel Int // 1-5 corresponding to DSE levels
  exampleSentence String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userProgress    UserVocabulary[]
}

model UserVocabulary {
  id              String     @id @default(uuid())
  userId          String
  vocabularyId    String
  difficulty      Int // 0=new, 1=known, 2=mastered
  repetitionCount Int        @default(0)
  easeFactor      Float      @default(2.5) // SM-2 algorithm factor
  interval        Int        @default(0) // days until next review
  nextReviewDate  DateTime
  lastReviewed    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  vocabulary      Vocabulary @relation(fields: [vocabularyId], references: [id])

  @@unique([userId, vocabularyId])
}

model SpeakingPhrase {
  id              String                 @id @default(uuid())
  phrase          String                 @unique
  translation     String
  phonetic        String? // IPA phonetic transcription
  difficultyLevel Int // 1-5 corresponding to DSE levels
  exampleSentence String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  userProgress    UserSpeakingPractice[]
}

model UserSpeakingPractice {
  id               String              @id @default(uuid())
  userId           String
  speakingPhraseId String
  masteryLevel     Int // 0=new, 1=learning, 2=mastered
  repetitionCount  Int                 @default(0)
  easeFactor       Float               @default(2.5) // SM-2 algorithm factor
  interval         Int                 @default(0) // days until next review
  nextReviewDate   DateTime
  lastReviewed     DateTime?
  lastScore        Float? // Last pronunciation score (0-100)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id])
  speakingPhrase   SpeakingPhrase      @relation(fields: [speakingPhraseId], references: [id])
  recordings       SpeakingRecording[]

  @@unique([userId, speakingPhraseId])
}

model SpeakingRecording {
  id             String                @id @default(uuid())
  userPracticeId String? // For pattern practice recordings
  questionId     String? // For mock exam question recordings
  userId         String
  audioData      Bytes? // Raw audio data (for storage)
  audioUrl       String? // Optional URL if stored externally
  transcription  String?
  accuracyScore  Float? // Word accuracy percentage
  stressScore    Float? // Stress/intonation score
  overallScore   Float? // Overall score
  feedback       String? // AI feedback text
  prompt         String? // Question prompt for mock exams
  createdAt      DateTime              @default(now())
  userPractice   UserSpeakingPractice? @relation(fields: [userPracticeId], references: [id])
  user           User                  @relation(fields: [userId], references: [id])
}

model ReadingPassage {
  id              String                @id @default(uuid())
  title           String
  content         String // Reading passage text
  difficultyLevel Int // 1-5 corresponding to DSE levels (1=easy, 5=hard)
  difficultyStar  String // "*" or "**" for DSE marking
  questions       Json // Array of questions with options and correct answers
  explanation     String? // General explanation for the passage
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  userPractices   UserReadingPractice[]
}

model UserReadingPractice {
  id               String         @id @default(uuid())
  userId           String
  readingPassageId String
  userAnswers      Json // Array of user's answers
  correctAnswers   Int // Number of correct answers
  totalQuestions   Int // Total number of questions
  percentageScore  Float // Score percentage
  completedAt      DateTime       @default(now())
  user             User           @relation(fields: [userId], references: [id])
  readingPassage   ReadingPassage @relation(fields: [readingPassageId], references: [id])
}

model ListeningExercise {
  id              String                  @id @default(uuid())
  title           String
  description     String? // Exercise description/context
  audioUrl        String? // Audio file URL (for older content)
  youtubeId       String? // YouTube video ID (embed directly)
  difficultyLevel Int // 1-5 corresponding to DSE levels (1=easy, 5=hard)
  difficultyStar  String // "*" or "**" for DSE marking
  questions       Json // Array of questions with options and correct answers
  explanation     String? // General explanation
  active          Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  userPractices   UserListeningPractice[]
}

model UserListeningPractice {
  id                  String            @id @default(uuid())
  userId              String
  listeningExerciseId String
  userAnswers         Json // Array of user's answers
  correctAnswers      Int // Number of correct answers
  totalQuestions      Int // Total number of questions
  percentageScore     Float // Score percentage
  completedAt         DateTime          @default(now())
  user                User              @relation(fields: [userId], references: [id])
  listeningExercise   ListeningExercise @relation(fields: [listeningExerciseId], references: [id])
}

model WritingPrompt {
  id              String                @id @default(uuid())
  title           String
  content         String // Writing prompt/question content
  part            String // "part1" or "part2" (DSE Part 1 / Part 2)
  difficultyLevel Int // 1-5 corresponding to DSE levels (1=easy, 5=hard)
  wordCountMin    Int // Minimum word count requirement
  wordCountMax    Int // Maximum word count requirement
  description     String? // Additional description/context
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  userPractices   UserWritingPractice[]
}

model UserWritingPractice {
  id                 String        @id @default(uuid())
  userId             String
  writingPromptId    String
  userEssay          String // User's written essay
  overallScore       Int // DSE score 1-5
  starRating         String // "*" or "**" for DSE marking
  vocabularyFeedback String // Vocabulary feedback
  grammarFeedback    String // Grammar feedback
  structureFeedback  String // Structure feedback
  contentFeedback    String // Content feedback
  suggestions        String // Improvement suggestions
  corrections        Json // Array of corrections: {original: string, correction: string, explanation: string}
  feedbackJson       String? // Full JSON feedback from AI
  completedAt        DateTime      @default(now())
  user               User          @relation(fields: [userId], references: [id])
  writingPrompt      WritingPrompt @relation(fields: [writingPromptId], references: [id])
}

model BiWeeklyReview {
  id               String         @id @default(uuid())
  userId           String
  learnerProfileId String
  startTime        DateTime       @default(now())
  completedAt      DateTime?
  totalQuestions   Int
  correctAnswers   Int
  percentageScore  Float?
  vocabCount       Int // Number of vocabulary items in this review
  phraseCount      Int // Number of speaking phrases in this review
  readingCount     Int // Number of reading questions in this review
  vocabCorrect     Int // Correct vocabulary answers
  phraseCorrect    Int // Correct phrase answers
  readingCorrect   Int // Correct reading answers
  nextReviewDate   DateTime
  reviewContent    Json // Stores the actual review questions/items
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id])
  learnerProfile   LearnerProfile @relation(fields: [learnerProfileId], references: [id])
}

model SpeakingMockQuestion {
  id              String   @id @default(uuid())
  questionNumber  Int // Question number in exam
  prompt          String // The question prompt/text
  topic           String // Topic category (e.g. "Education", "Environment")
  preparationTime Int // Preparation time in seconds
  responseTime    Int // Response time in seconds
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GrammarQuestion {
  id              String                @id @default(uuid())
  title           String
  content         String // The grammar question content with blank
  description     String? // Additional description/context
  difficultyLevel Int // 1-5 corresponding to DSE levels (1=easy, 5=hard)
  options         Json // Array of 4 options: ["option A", "option B", ...]
  correctAnswer   Int // 0-3 index of correct answer
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  userPractices   UserGrammarPractice[]
}

model UserGrammarPractice {
  id                String          @id @default(uuid())
  userId            String
  grammarQuestionId String
  userAnswer        Int // User's answer index (0-3)
  isCorrect         Boolean
  completedAt       DateTime        @default(now())
  user              User            @relation(fields: [userId], references: [id])
  grammarQuestion   GrammarQuestion @relation(fields: [grammarQuestionId], references: [id])

  @@unique([userId, grammarQuestionId])
}
